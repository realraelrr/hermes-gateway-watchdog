# Hermes Gateway Watchdog config example
# Precedence: process env > WATCHDOG_ENV_FILE > defaults
#
# Leave path overrides blank to use:
# - HERMES_HOME=$HOME/.hermes
# - WATCHDOG_HOME=$HOME/.hermes-watchdog

# Optional path overrides
HERMES_HOME=
WATCHDOG_HOME=
WATCHDOG_STATE_DIR=
WATCHDOG_LOG_DIR=
WATCHDOG_ENV_FILE=
WATCHDOG_DISABLE_FILE=

# Runtime behavior
WATCHDOG_DISPLAY_NAME=Hermes Gateway Watchdog
NOTIFIER=composite
WATCHDOG_ENABLED=1
FAIL_THRESHOLD=3
MAX_RESTART_FAILURES=10
COOLDOWN_SEC=300
POST_RESTART_RETRIES=3
POST_RESTART_SLEEP_SEC=5
INITIAL_GRACE_SEC=60
TRANSITION_GRACE_SEC=45
LOCK_STALE_SEC=120
GATEWAY_STATE_MAX_AGE_SEC=90

# Service labels and local probes
GATEWAY_LABEL=com.hermes.gateway
CLOUDFLARED_LABEL=com.cloudflare.cloudflared
CLOUDFLARED_READY_URL=http://127.0.0.1:20241/ready
FEISHU_WEBHOOK_PROBE_URL=http://127.0.0.1:8765/feishu/webhook

# Optional binary overrides
CURL_BIN=
JQ_BIN=
LAUNCHCTL_BIN=
LSOF_BIN=

# Optional webhook targets
DISCORD_WATCHDOG_WEBHOOK_URL=
FEISHU_WATCHDOG_WEBHOOK_URL=
